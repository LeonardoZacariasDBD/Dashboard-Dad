class RoutesPage extends StatefulWidget {
  const RoutesPage({super.key});

  @override
  State<RoutesPage> createState() => _RoutesPageState();
}

class _RoutesPageState extends State<RoutesPage> {
  // Default fallback spot (Grand Island/Central City zone) until true GPS locks on
  LatLng _currentLocation = const LatLng(40.9250, -98.3700); 
  bool _isLoading = true;
  String _statusMessage = 'Locking onto Hardware Satellite Streams...';
  bool _isTrackingEnabled = true;
  bool _lockCameraToRig = true; 

  final MapController _mapController = MapController();
  List<Marker> _dynamicTruckStopMarkers = [];
  Map<String, double> _stateMileageLogs = {};
  LatLng? _lastRecordedLocation;
  
  StreamSubscription<Position>? _positionStreamSubscription;

  // Real-world, absolute precision coordinates matching physical asphalt locations
  final List<Map<String, dynamic>> _nationwidePoiDatabase = [
    // --- NEBRASKA PINPOINT ACCURATE HIGHWAY PLAZAS ---
    {'name': 'Pilot Travel Center #421', 'details': 'Fuel: \$3.72/gal\nGrand Island, NE (I-80 Exit 312).', 'lat': 40.8911, 'lng': -98.3790, 'type': 'cheapest'},
    {'name': 'Bosselman Travel Center', 'details': 'Fuel: \$3.95/gal\nGrand Island, NE (I-80 Exit 314).', 'lat': 40.8872, 'lng': -98.3184, 'type': 'standard'},
    {'name': 'Loves Travel Stop #621', 'details': 'Fuel: \$3.89/gal\nNorth Platte, NE (I-80 Exit 177).', 'lat': 41.1190, 'lng': -100.7580, 'type': 'standard'},
    {'name': 'Pilot Travel Center #485', 'details': 'Fuel: \$3.85/gal\nNorth Platte, NE (I-80 Exit 179).', 'lat': 41.1175, 'lng': -100.7410, 'type': 'standard'},
    {'name': 'Flying J Plaza #622', 'details': 'Fuel: \$3.88/gal\nBig Springs, NE (I-80 Exit 107).', 'lat': 41.0624, 'lng': -102.0735, 'type': 'parking'},
    {'name': 'Loves Travel Stop #615', 'details': 'Fuel: \$3.91/gal\nSidney, NE (I-80 Exit 59).', 'lat': 41.1130, 'lng': -102.9490, 'type': 'standard'},
    {'name': 'Shoemaker Truck Station', 'details': 'Fuel: \$3.87/gal\nLincoln, NE (I-80 Exit 395).', 'lat': 40.8310, 'lng': -96.7725, 'type': 'standard'},
  ];

  @override
  void initState() {
    super.initState();
    _loadDataFromCache();
  }

  @override
  void dispose() {
    _positionStreamSubscription?.cancel();
    _mapController.dispose();
    super.dispose();
  }

  Future<void> _loadDataFromCache() async {
    final SharedPreferences prefs = await SharedPreferences.getInstance();
    _isTrackingEnabled = prefs.getBool('ifta_tracking_switch') ?? true;

    final String? savedMileageRaw = prefs.getString('saved_state_mileage');
    if (savedMileageRaw != null) {
      final Map<String, dynamic> decodedMap = jsonDecode(savedMileageRaw);
      setState(() {
        _stateMileageLogs = decodedMap.map((key, value) => MapEntry(key, (value as num).toDouble()));
      });
    } else {
      setState(() {
        _stateMileageLogs = {'NE': 0.0, 'IA': 0.0};
      });
      _saveDataToCache();
    }
    _startLiveLocationTracking();
  }

  Future<void> _saveDataToCache() async {
    final SharedPreferences prefs = await SharedPreferences.getInstance();
    await prefs.setBool('ifta_tracking_switch', _isTrackingEnabled);
    await prefs.setString('saved_state_mileage', jsonEncode(_stateMileageLogs));
  }

  // Pure hardware connection method
  Future<void> _startLiveLocationTracking() async {
    bool serviceEnabled = await Geolocator.isLocationServiceEnabled();
    if (!serviceEnabled) {
      _showErrorState('Location services are completely disabled on this device.');
      return;
    }

    LocationPermission permission = await Geolocator.checkPermission();
    if (permission == LocationPermission.denied) {
      permission = await Geolocator.requestPermission();
      if (permission == LocationPermission.denied) {
        _showErrorState('Location permissions were denied by user request.');
        return;
      }
    }

    if (permission == LocationPermission.deniedForever) {
      _showErrorState('Location permissions are permanently locked out in OS settings.');
      return;
    }

    try {
      // Get exact initial fix position on screen entry
      Position position = await Geolocator.getCurrentPosition(
        locationSettings: const LocationSettings(accuracy: LocationAccuracy.high),
      );

      if (mounted) {
        setState(() {
          _currentLocation = LatLng(position.latitude, position.longitude);
          _lastRecordedLocation = _currentLocation;
          _isLoading = false;
        });
        WidgetsBinding.instance.addPostFrameCallback((_) => _forceUpdateMapLayout());
      }
    } catch (e) {
      _showErrorState('Failed to grab an initial satellite lock: $e');
    }

    // Connect directly to live position change events as you drive down the road
    _positionStreamSubscription = Geolocator.getPositionStream(
      locationSettings: const LocationSettings(
        accuracy: LocationAccuracy.high, 
        distanceFilter: 5, // Triggers every 5 meters (~16 feet) of actual vehicle movement
      ),
    ).listen((Position newPosition) {
      if (mounted && _isTrackingEnabled) {
        _processNewCoordinates(LatLng(newPosition.latitude, newPosition.longitude));
      }
    });
  }

  void _showErrorState(String errorMsg) {
    setState(() {
      _statusMessage = errorMsg;
      _isLoading = false;
    });
  }

  void _processNewCoordinates(LatLng targetCoord) {
    setState(() {
      _currentLocation = targetCoord;
    });

    if (_lockCameraToRig) {
      _mapController.move(_currentLocation, _mapController.camera.zoom);
    }

    // Dynamic distance calculation for real IFTA tracking logs
    if (_lastRecordedLocation != null) {
      double distanceInMeters = Geolocator.distanceBetween(
        _lastRecordedLocation!.latitude,
        _lastRecordedLocation!.longitude,
        targetCoord.latitude,
        targetCoord.longitude,
      );
      
      double drivenMiles = distanceInMeters * 0.000621371; // Convert meters to miles
      
      if (drivenMiles > 0.01) {
        String detectedState = 'NE';
        // Basic coordinate dividing line for example context
        if (targetCoord.longitude > -96.0) {
          detectedState = 'IA';
        }

        setState(() {
          final double existingMiles = _stateMileageLogs[detectedState] ?? 0.0;
          _stateMileageLogs[detectedState] = double.parse((existingMiles + drivenMiles).toStringAsFixed(2));
        });
        _lastRecordedLocation = targetCoord;
        _saveDataToCache();
      }
    } else {
      _lastRecordedLocation = targetCoord;
    }

    _forceUpdateMapLayout();
  }

  // Evaluates dynamic viewport bounds instantly based on what you see on screen
  void _forceUpdateMapLayout() {
    if (!mounted) return;
    
    List<Marker> localizedMarkers = [];

    // Place the Rig at your exact physical location
    localizedMarkers.add(
      Marker(
        point: _currentLocation,
        width: 65,
        height: 65,
        child: const Icon(Icons.local_shipping, color: Colors.blueAccent, size: 44),
      ),
    );

    final currentVisibleBounds = _mapController.camera.visibleBounds;

    for (var poi in _nationwidePoiDatabase) {
      final LatLng poiLatLng = LatLng(poi['lat'], poi['lng']);
      
      // Dynamic visibility culling
      if (currentVisibleBounds.contains(poiLatLng)) {
        Color iconColor = Colors.amber;
        IconData iconData = Icons.local_gas_station;

        if (poi['type'] == 'cheapest') {
          iconColor = Colors.green;
        } else if (poi['type'] == 'parking') {
          iconColor = Colors.lightBlue;
          iconData = Icons.local_parking;
        }

        localizedMarkers.add(
          Marker(
            point: poiLatLng,
            width: 50,
            height: 50,
            child: GestureDetector(
              onTap: () => _showStopDetails(poi['name'], poi['details']),
              child: Icon(iconData, color: iconColor, size: 34),
            ),
          ),
        );
      }
    }

    setState(() {
      _dynamicTruckStopMarkers = localizedMarkers;
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('LIVE GPS NAVIGATION & IFTA'),
        backgroundColor: const Color(0xFF1F1F1F),
        actions: [
          IconButton(
            icon: Icon(
              _lockCameraToRig ? Icons.gps_fixed : Icons.gps_not_fixed,
              color: _lockCameraToRig ? Colors.amber : Colors.grey,
            ),
            onPressed: () {
              setState(() {
                _lockCameraToRig = !_lockCameraToRig;
              });
              if (_lockCameraToRig) {
                _mapController.move(_currentLocation, _mapController.camera.zoom);
              }
            },
          )
        ],
      ),
      body: _isLoading
          ? Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  const CircularProgressIndicator(color: Colors.amber),
                  const SizedBox(height: 16),
                  Text(_statusMessage, style: const TextStyle(color: Colors.grey)),
                ],
              ),
            )
          : Stack(
              children: [
                FlutterMap(
                  mapController: _mapController,
                  options: MapOptions(
                    initialCenter: _currentLocation,
                    initialZoom: 14.0, // Zoomed into cab-view level
                    maxZoom: 18,
                    minZoom: 3,
                    onPositionChanged: (camera, hasGesture) {
                      if (hasGesture && _lockCameraToRig) {
                        setState(() {
                          _lockCameraToRig = false;
                        });
                      }
                      _forceUpdateMapLayout(); // Refreshes markers automatically during gestures
                    },
                  ),
                  children: [
                    TileLayer(
                      urlTemplate: 'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
                      userAgentPackageName: 'com.dashboarddad.app',
                    ),
                    MarkerLayer(markers: _dynamicTruckStopMarkers),
                  ],
                ),
                Positioned(
                  top: 16,
                  left: 16,
                  right: 16,
                  child: Card(
                    color: const Color(0xF61F1F1F),
                    shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
                    child: Padding(
                      padding: const EdgeInsets.all(14.0),
                      child: Column(
                        mainAxisSize: MainAxisSize.min,
                        children: [
                          Row(
                            mainAxisAlignment: MainAxisAlignment.spaceBetween,
                            children: [
                              Row(
                                children: [
                                  Icon(Icons.satellite_alt, 
                                    color: _lockCameraToRig ? Colors.green : Colors.orangeAccent
                                  ),
                                  const SizedBox(width: 10),
                                  Text(
                                    _lockCameraToRig ? 'SATELLITE LOCK ACQUIRED' : 'FREE SCROLL MODE',
                                    style: const TextStyle(fontWeight: FontWeight.bold, fontSize: 13),
                                  ),
                                ],
                              ),
                              Switch(
                                value: _isTrackingEnabled,
                                activeThumbColor: Colors.amber,
                                onChanged: (value) {
                                  setState(() {
                                    _isTrackingEnabled = value;
                                  });
                                  _saveDataToCache();
                                },
                              )
                            ],
                          ),
                          const Divider(color: Colors.white24, height: 16),
                          Row(
                            mainAxisAlignment: MainAxisAlignment.spaceAround,
                            children: _stateMileageLogs.entries.map((entry) {
                              return Column(
                                children: [
                                  Text(entry.key, style: const TextStyle(fontWeight: FontWeight.bold, fontSize: 15)),
                                  Text('${entry.value.toStringAsFixed(2)} mi', style: const TextStyle(color: Colors.grey, fontSize: 12)),
                                ],
                              );
                            }).toList(),
                          ),
                        ],
                      ),
                    ),
                  ),
                ),
              ],
            ),
    );
  }

  void _showStopDetails(String stopName, String information) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        backgroundColor: const Color(0xFF1F1F1F),
        title: Text(stopName, style: const TextStyle(color: Colors.amber, fontWeight: FontWeight.bold)),
        content: Text(information, style: const TextStyle(color: Colors.white)),
        actions: [
          TextButton(onPressed: () => Navigator.pop(context), child: const Text('DISMISS', style: TextStyle(color: Colors.amber)))
        ],
      ),
    );
  }
}

class FuelHistoryPage extends StatefulWidget {
  const FuelHistoryPage({super.key});

  @override
  State<FuelHistoryPage> createState() => _FuelHistoryPageState();
}

class _FuelHistoryPageState extends State<FuelHistoryPage> {
  List<Map<String, String>> _fuelLogs = [];
  bool _isLoadingLogs = true;

  final TextEditingController _stateController = TextEditingController();
  final TextEditingController _gallonsController = TextEditingController();
  final TextEditingController _costController = TextEditingController();

  @override
  void initState() {
    super.initState();
    _loadLogsFromStorage();
  }

  Future<void> _loadLogsFromStorage() async {
    final SharedPreferences prefs = await SharedPreferences.getInstance();
    final String? savedLogsRaw = prefs.getString('saved_fuel_logs');

    if (savedLogsRaw != null) {
      final List<dynamic> decodedList = jsonDecode(savedLogsRaw);
      setState(() {
        _fuelLogs = decodedList.map((item) => Map<String, String>.from(item)).toList();
        _isLoadingLogs = false;
      });
    } else {
      setState(() {
        _fuelLogs = [
          {'date': '05/14/2026', 'state': 'NE', 'gallons': '120.5', 'cost': '\$455.20'},
          {'date': '05/11/2026', 'state': 'IA', 'gallons': '145.2', 'cost': '\$540.15'},
        ];
        _isLoadingLogs = false;
      });
      _saveLogsToStorage();
    }
  }

  Future<void> _saveLogsToStorage() async {
    final SharedPreferences prefs = await SharedPreferences.getInstance();
    final String encodedData = jsonEncode(_fuelLogs);
    await prefs.setString('saved_fuel_logs', encodedData);
  }

  void _confirmDeleteLog(int index) {
    showDialog(
      context: context,
      builder: (BuildContext context) {
        return AlertDialog(
          backgroundColor: const Color(0xFF1F1F1F),
          shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
          title: const Text(
            'CONFIRM DELETION',
            style: TextStyle(fontWeight: FontWeight.bold, color: Colors.amber, letterSpacing: 1),
          ),
          content: const Text(
            'Are you sure you want to delete this fuel record? This choice is absolute and cannot be undone.',
            style: TextStyle(color: Colors.white70),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.pop(context),
              child: const Text('CANCEL', style: TextStyle(color: Colors.grey, fontWeight: FontWeight.bold)),
            ),
            TextButton(
              onPressed: () {
                setState(() {
                  _fuelLogs.removeAt(index);
                });
                _saveLogsToStorage();
                Navigator.pop(context);
                ScaffoldMessenger.of(context).showSnackBar(
                  const SnackBar(
                    content: Text('Record deleted permanently from device storage.'),
                    backgroundColor: Colors.redAccent,
                  ),
                );
              },
              child: const Text('DELETE', style: TextStyle(color: Colors.red, fontWeight: FontWeight.bold)),
            ),
          ],
        );
      },
    );
  }

  void _addNewLog() {
    final String enteredState = _stateController.text.trim().toUpperCase();
    final String enteredGallons = _gallonsController.text.trim();
    final String enteredCost = _costController.text.trim();

    if (enteredState.isEmpty || enteredGallons.isEmpty || enteredCost.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Please fill out all fields before saving.')),
      );
      return;
    }

    final double? verifiedGallons = double.tryParse(enteredGallons);
    if (verifiedGallons == null) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Invalid volume format. Please supply a valid decimal number.')),
      );
      return;
    }

    final DateTime now = DateTime.now();
    final String formattedDate = "${now.month.toString().padLeft(2, '0')}/${now.day.toString().padLeft(2, '0')}/${now.year}";

    setState(() {
      _fuelLogs.insert(0, {
        'date': formattedDate,
        'state': enteredState,
        'gallons': enteredGallons,
        'cost': enteredCost.startsWith('\$') ? enteredCost : '\$$enteredCost',
      });
    });
    _saveLogsToStorage();

    _stateController.clear();
    _gallonsController.clear();
    _costController.clear();
    Navigator.pop(context);
  }

  void _openInputFormDrawer() {
    showModalBottomSheet(
      context: context,
      isScrollControlled: true,
      backgroundColor: const Color(0xFF1F1F1F),
      shape: const RoundedRectangleBorder(borderRadius: BorderRadius.vertical(top: Radius.circular(24))),
      builder: (context) {
        return Padding(
          padding: EdgeInsets.only(
            top: 24,
            left: 24,
            right: 24,
            bottom: MediaQuery.of(context).viewInsets.bottom + 24,
          ),
          child: Column(
            mainAxisSize: MainAxisSize.min,
            crossAxisAlignment: CrossAxisAlignment.stretch,
            children: [
              const Text(
                'LOG NEW FUEL TRANSACTION',
                style: TextStyle(fontSize: 20, fontWeight: FontWeight.bold, letterSpacing: 1),
                textAlign: TextAlign.center,
              ),
              const SizedBox(height: 20),
              TextField(
                controller: _stateController,
                decoration: const InputDecoration(labelText: 'State Jurisdiction (e.g., NE, IA, WY)', border: OutlineInputBorder()),
                textCapitalization: TextCapitalization.characters,
              ),
              const SizedBox(height: 16),
              TextField(
                controller: _gallonsController,
                decoration: const InputDecoration(labelText: 'Gallons Pumped', border: OutlineInputBorder()),
                keyboardType: const TextInputType.numberWithOptions(decimal: true),
              ),
              const SizedBox(height: 16),
              TextField(
                controller: _costController,
                decoration: const InputDecoration(labelText: 'Total Cost (\$)', border: OutlineInputBorder()),
                keyboardType: const TextInputType.numberWithOptions(decimal: true),
              ),
              const SizedBox(height: 24),
              ElevatedButton(
                onPressed: _addNewLog,
                style: ElevatedButton.styleFrom(
                  backgroundColor: Colors.amber,
                  foregroundColor: Colors.black,
                  padding: const EdgeInsets.symmetric(vertical: 16),
                  shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
                ),
                child: const Text('SAVE RECORD TO DATABASE', style: TextStyle(fontWeight: FontWeight.bold, fontSize: 16)),
              ),
            ],
          ),
        );
      },
    );
  }

  @override
  void dispose() {
    _stateController.dispose();
    _gallonsController.dispose();
    _costController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('FUEL HISTORY RECORDS'),
        backgroundColor: const Color(0xFF1F1F1F),
      ),
      body: _isLoadingLogs
          ? const Center(child: CircularProgressIndicator(color: Colors.amber))
          : _fuelLogs.isEmpty
              ? const Center(
                  child: Text(
                    'No fuel logs recorded yet.',
                    style: TextStyle(fontSize: 16, color: Colors.grey, fontStyle: FontStyle.italic),
                  ),
                )
              : ListView.builder(
                  padding: const EdgeInsets.all(16.0),
                  itemCount: _fuelLogs.length,
                  itemBuilder: (context, index) {
                    final log = _fuelLogs[index];
                    return Card(
                      color: const Color(0xFF1F1F1F),
                      margin: const EdgeInsets.only(bottom: 12),
                      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
                      child: ListTile(
                        leading: const CircleAvatar(
                          backgroundColor: Colors.amber,
                          child: Icon(Icons.local_gas_station, color: Colors.black),
                        ),
                        title: Text(
                          'State: ${log['state']} — ${log['gallons']} Gallons',
                          style: const TextStyle(fontWeight: FontWeight.bold),
                        ),
                        subtitle: Text('Date: ${log['date']}'),
                        trailing: Row(
                          mainAxisSize: MainAxisSize.min,
                          children: [
                            Text(
                              log['cost']!,
                              style: const TextStyle(color: Colors.green, fontWeight: FontWeight.bold, fontSize: 16),
                            ),
                            const SizedBox(width: 8),
                            IconButton(
                              icon: const Icon(Icons.delete_outline, color: Colors.redAccent),
                              tooltip: 'Remove Log',
                              onPressed: () => _confirmDeleteLog(index),
                            ),
                          ],
                        ),
                      ),
                    );
                  },
                ),
      floatingActionButton: FloatingActionButton.extended(
        onPressed: _openInputFormDrawer,
        backgroundColor: Colors.amber,
        foregroundColor: Colors.black,
        icon: const Icon(Icons.add),
        label: const Text('LOG FUEL PUMP', style: TextStyle(fontWeight: FontWeight.bold)),
      ),
    );
  }
}
